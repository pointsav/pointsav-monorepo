# =======================================================
# POINTSAV DIGITAL SYSTEMS - TOTEBOX INDEX CARD
# Copy to totebox-index.env and fill in values.
# NEVER commit totebox-index.env to version control.
# =======================================================

# 1. AZURE IDENTITY GATEWAY
AZURE_TENANT_ID="<INSERT_TENANT_ID>"
AZURE_CLIENT_ID="<INSERT_CLIENT_ID>"
AZURE_CLIENT_SECRET="<INSERT_CLIENT_SECRET>"

# 2. EXCHANGE TARGET (The Mailbox being extracted)
EXCHANGE_TARGET_USER="<target@domain.com>"
ARCHIVE_OWNER="<username>"

# 3. PHYSICAL EGRESS ROUTING (External Drive Isolation)
# MacPro Target Path Example: /Volumes/SOVEREIGN1/vault-staging
# Linux Target Path Example: /media/username/SOVEREIGN1/vault-staging
PHYSICAL_USB_PATH="<path-to-external-drive>/vault-staging"

# 4. ENGINE PARAMETERS
EWS_BATCH_SIZE=100
NETWORK_RETRY_LIMIT=5
