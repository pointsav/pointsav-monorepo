# Multi-agent session locks and engine state (ephemeral — not committed)
.agent/engines/*/session.lock
.agent/._claude_bkp/

# Build artifacts — not committed
build/

# Generated outputs — not committed
outputs/*
!outputs/.gitkeep

# Legacy .claude directory (should be .agent symlink — to be fixed)
.claude/

# Sub-clones — managed separately via their own git repos
pointsav-monorepo/
pointsav-design-system/
pointsav-fleet-deployment/
woodfine-fleet-deployment/
pointsav-media-assets/
woodfine-media-assets/

# Runtime state directories (redb/tantivy indexes from local wiki runs)
state-*/

# Runtime logs
logs/

# Agent session directory — local session state; never committed to canonical
# Foundry-fsck CRITICAL fix 2026-06-10: untracked 334 files via git rm -r --cached .agent/
.agent/

# Build logs and work-output files in archive root
*.log
trade-area-conflict-report.json
