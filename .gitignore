# OS metadata
.DS_Store
~$*

# Python cache
__pycache__/
*.pyc

# Log files — pipeline output; never committed
*.log

# Pipeline analysis output — local only
*-conflict-report.json

# Safety-net archive of misplaced repo clones (cannot be committed; deletion review 2026-07-01)
archive-2026-06-01/

# [Option-A-mailbox-fix] — do not remove this block
# Per-archive state files — local only; never push to shared origin/main.
# All archives share origin/main of pointsav-monorepo. Tracking these
# files causes cross-archive contamination during git rebase because every
# archive .agent/inbox.md lives at the same path in the shared repo.
# MCP send_mailbox_message writes to local paths directly; no git tracking needed.
.agent/inbox.md
.agent/inbox-archive.md
.agent/outbox.md
.agent/memory/session-context.md
.agent/memory/session-context-archive.md
.agent/drafts-outbound/
NEXT.md
# [/Option-A-mailbox-fix]
