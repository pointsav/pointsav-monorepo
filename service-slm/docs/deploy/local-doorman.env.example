# local-doorman.service environment file — workspace VM dogfood deploy
# Generated by project-slm cluster iter-19; mirrors slm-doorman-server::main env-var contract
# To use: systemd unit's EnvironmentFile= line points at /etc/local-doorman/local-doorman.env
# Variables marked OPTIONAL can be left empty; required ones are noted.
#
# The inline local-doorman.service unit at infrastructure/local-doorman/local-doorman.service
# carries Environment= directives inline for baseline values. This file is the
# operator-managed override layer: create it, populate it, and reference it from the unit's
# EnvironmentFile= directive (or a drop-in override). Variables here take precedence over
# the unit's inline Environment= lines.
#
# All env vars are documented against the source: slm-doorman-server::main.rs


# ──────────────────────────────────────────────────────────────────────────────
# Network binding
# ──────────────────────────────────────────────────────────────────────────────

# Socket address the Doorman listens on.
# Workspace VM dogfood: loopback only (no TLS termination required for local traffic).
# Production: change to 0.0.0.0:9080 behind an nginx TLS terminator.
SLM_BIND_ADDR=127.0.0.1:9080


# ──────────────────────────────────────────────────────────────────────────────
# Tier A — local inference (required for basic operation)
# ──────────────────────────────────────────────────────────────────────────────

# Base URL of the OpenAI-compatible local SLM endpoint (Ring 3a Tier A).
# Must match the local-slm.service bind address. Default: http://127.0.0.1:8080
SLM_LOCAL_ENDPOINT=http://127.0.0.1:8080

# Model identifier forwarded in requests to the Tier A endpoint.
# Must match the model filename the local-slm.service loaded at boot.
# Default: olmo-3-7b-instruct
SLM_LOCAL_MODEL=Olmo-3-1125-7B-Think-Q4_K_M.gguf


# ──────────────────────────────────────────────────────────────────────────────
# Tier B — Yo-Yo GCE inference (OPTIONAL; community-tier mode if absent)
# ──────────────────────────────────────────────────────────────────────────────
# Leave all SLM_YOYO_* variables empty or unset to run in community-tier mode
# (Tier A only). The Doorman boots cleanly in this configuration per
# conventions/three-ring-architecture.md Optional Intelligence principle.
# Tier B activation is a separate Master decision gated on the D4 GCE image
# build + billing-cap + kill-switch setup.

# Base URL of the Yo-Yo GCE inference endpoint (e.g. https://35.x.x.x:9080).
# When unset or empty, Tier B is disabled (has_yoyo=false in /readyz).
# OPTIONAL
SLM_YOYO_ENDPOINT=

# Static bearer token for Tier B authentication. Used by StaticBearer provider.
# Real GCP Workload Identity deployments replace this with a provider-specific
# BearerTokenProvider; this value is the dev/staging shortcut.
# OPTIONAL; only read when SLM_YOYO_ENDPOINT is set.
SLM_YOYO_BEARER=

# Model identifier forwarded in requests to the Tier B endpoint.
# Default: Olmo-3-1125-32B-Think
# OPTIONAL; only read when SLM_YOYO_ENDPOINT is set.
SLM_YOYO_MODEL=Olmo-3-1125-32B-Think

# Per-provider hourly USD rate used to compute cost_usd in the audit ledger.
# Used for cost accounting only; does not affect routing.
# Default: 0.0 (unknown/dev). Set to actual GCE rate when Yo-Yo is live
# (example: 0.84 for GCP L4, 0.34 for RunPod L4, ~0.50-0.70 for A100 preemptible).
# OPTIONAL; only read when SLM_YOYO_ENDPOINT is set.
SLM_YOYO_HOURLY_USD=0.0

# Prometheus metric name for active-request detection by the idle monitor.
# llama-server (llama.cpp):  llama_active_slots_total   ← default; backward compat
# vLLM:                      vllm:num_requests_running  ← set this for Yo-Yo #1
# OPTIONAL; defaults to llama_active_slots_total when unset.
SLM_YOYO_METRICS_KEY=vllm:num_requests_running

# GCP idle monitor — all four vars required to enable automatic VM stop after
# SLM_YOYO_IDLE_MINUTES of inactivity. If any one is absent the idle monitor
# does not start (no auto-stop; VM runs until stopped manually).
# OPTIONAL
SLM_YOYO_GCP_PROJECT=woodfine-node-gcp-free
SLM_YOYO_GCP_ZONE=us-central1-a
SLM_YOYO_GCP_INSTANCE=yoyo-tier-b-1
SLM_YOYO_IDLE_MINUTES=30


# ──────────────────────────────────────────────────────────────────────────────
# Tier C — external API providers (OPTIONAL; controls audit_proxy endpoint)
# ──────────────────────────────────────────────────────────────────────────────
# TODO: uncomment + supply Anthropic API key when audit_proxy use becomes
# operational. Until then, POST /v1/audit/proxy returns 503 with:
#   "audit_proxy unconfigured: no Tier C providers found in environment"
# This is correct and expected behavior in the workspace dogfood deploy.
#
# The SLM_TIER_C_* namespace is shared between Tier C routing (/v1/chat/completions
# with x-foundry-tier-c-label header) and the audit proxy (/v1/audit/proxy).
# Configuring one provider here enables both surfaces.

# Anthropic
#SLM_TIER_C_ANTHROPIC_ENDPOINT=https://api.anthropic.com
#SLM_TIER_C_ANTHROPIC_API_KEY=sk-ant-...
#SLM_TIER_C_ANTHROPIC_INPUT_PER_MTOK_USD=3.00
#SLM_TIER_C_ANTHROPIC_OUTPUT_PER_MTOK_USD=15.00

# Gemini
#SLM_TIER_C_GEMINI_ENDPOINT=https://generativelanguage.googleapis.com
#SLM_TIER_C_GEMINI_API_KEY=AIza...
#SLM_TIER_C_GEMINI_INPUT_PER_MTOK_USD=0.075
#SLM_TIER_C_GEMINI_OUTPUT_PER_MTOK_USD=0.30

# OpenAI
#SLM_TIER_C_OPENAI_ENDPOINT=https://api.openai.com
#SLM_TIER_C_OPENAI_API_KEY=sk-...
#SLM_TIER_C_OPENAI_INPUT_PER_MTOK_USD=2.50
#SLM_TIER_C_OPENAI_OUTPUT_PER_MTOK_USD=10.00


# ──────────────────────────────────────────────────────────────────────────────
# Apprenticeship Substrate (AS-2 / AS-3 / AS-4)
# ──────────────────────────────────────────────────────────────────────────────

# Enable the three apprenticeship endpoints: POST /v1/brief, /v1/verdict, /v1/shadow.
# Default: false (endpoints return 404).
# Workspace dogfood: enable now — B7 is the gate that lights up the apprenticeship arm.
# Set to "true" or "1" to enable.
SLM_APPRENTICESHIP_ENABLED=true

# Workspace root. Used by the apprenticeship dispatcher to resolve scope.files
# paths and read citations.yaml. Default: /srv/foundry.
FOUNDRY_ROOT=/srv/foundry

# Char-budget proxy for Tier B routing on /v1/brief.
# Briefs whose body + acceptance_test length exceeds this threshold dispatch
# to Tier B (Yo-Yo). Default: 8000 chars (~2000 tokens).
# Workspace dogfood: default is appropriate.
SLM_BRIEF_TIER_B_THRESHOLD_CHARS=8000

# Doctrine version embedded in apprenticeship corpus tuples.
# Default: 0.0.7. Update when the workspace doctrine version bumps.
FOUNDRY_DOCTRINE_VERSION=0.0.7

# Tenant tag on corpus tuples.
# Default: pointsav. Woodfine deployments set this to woodfine.
FOUNDRY_TENANT=pointsav

# Path to the allowed_signers file used by AS-3 /v1/verdict ssh-keygen -Y verify.
# Default: ${FOUNDRY_ROOT}/identity/allowed_signers.
# Override if the workspace identity store is at a non-standard path.
# OPTIONAL
FOUNDRY_ALLOWED_SIGNERS=/srv/foundry/identity/allowed_signers


# ──────────────────────────────────────────────────────────────────────────────
# Grammar pre-validation (PS.3)
# ──────────────────────────────────────────────────────────────────────────────

# Pre-validate Lark grammars at the Doorman boundary using llguidance (PS.3 step 5).
# Default: true. Set to "false" or "0" to disable
# (e.g., if the llguidance initialisation overhead is undesirable in a test
# environment that never submits Lark grammars).
# Workspace dogfood: leave enabled.
SLM_LARK_VALIDATION_ENABLED=true


# ──────────────────────────────────────────────────────────────────────────────
# Audit ledger
# ──────────────────────────────────────────────────────────────────────────────

# Directory for the append-only JSONL audit ledger.
# If unset, defaults to $HOME/.service-slm/audit/ (where HOME is the service
# user's home directory, set by the systemd unit as HOME=/var/lib/local-doorman).
# Workspace dogfood: explicit path under /var/lib/local-doorman for clarity.
# Must be writable by the local-doorman service user.
SLM_AUDIT_DIR=/var/lib/local-doorman/audit/

# Maximum concurrent in-flight audit requests per tenant (moduleId) across BOTH
# /v1/audit/proxy and /v1/audit/capture. Excess requests return 503 with Retry-After: 5.
# Default: 4.
# Workspace dogfood is single-tenant; a higher cap prevents spurious throttling
# during active development. Raise further for multi-tenant production deployments.
SLM_AUDIT_TENANT_CONCURRENCY_CAP=16


# ──────────────────────────────────────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────────────────────────────────────

# Tracing filter (tracing_subscriber EnvFilter format).
# Default: slm_doorman=info,slm_doorman_server=info,axum=warn
# Increase to =debug for detailed request tracing during initial deploy.
RUST_LOG=slm_doorman=info,slm_doorman_server=info,axum=warn
