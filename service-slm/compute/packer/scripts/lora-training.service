[Unit]
Description=Yo-Yo LoRA training watcher (apprenticeship corpus → adapter)
Documentation=file:///var/log/yoyo-lora-training.log
After=vllm.service
Requires=vllm.service

[Service]
Type=simple
ExecStart=/usr/local/bin/lora-training.sh
Restart=on-failure
RestartSec=60
StandardOutput=journal
StandardError=journal

# This unit is intentionally NOT enabled in [Install] — the WantedBy line is
# absent so `systemctl enable lora-training.service` is a deliberate operator
# action, not a side effect of provisioning. Activation requires Master
# ratification of the Yo-Yo-runs-LoRA-training Doctrine claim.
#
# To activate after ratification:
#   sudo systemctl enable --now lora-training.service
