[Unit]
Description=llama.cpp OpenAI-compatible inference server (Yo-Yo Tier B)
After=vllm-weights-prep.service network.target
Requires=vllm-weights-prep.service

# Flag corrections verified live 2026-06-01 (BRIEF-slm-substrate-master.md §2.8):
#  -np 1  : with -c 2048, -np 4 would split context to 512 tok/slot → insufficient for
#           32B-Think reasoning chain. -np 1 = full 2048/slot.
#  -fa on : the current llama.cpp build requires a value for --flash-attn; bare -fa consumes
#           the next flag as its value and llama-server exits 1 on startup.
#  -c 2048: reduced from 4096 after Jun-04 OOM incident (VM OOM with MemoryMax=8G). KV cache at
#           4096 ctx caused llama-server to consume ~8G RSS → OOM kill. 2048 confirmed stable.
#           (To restore 4-way concurrency use -c 4096 -np 4 with MemoryMax ≥ 16G)
# NOTE: this image still does NOT fix extraction — the Doorman /v1/extract JSON-schema grammar
# does not constrain the 32B (unconstrained output → defer). That is a slm-doorman CODE fix;
# do not rebuild expecting extraction to work until it lands. See service-slm/NEXT.md.
[Service]
Type=simple
ExecStart=/opt/llama.cpp/build/bin/llama-server \
    -m /data/weights/olmo-3-32b-think-q3.gguf \
    -ngl 99 \
    --host 127.0.0.1 \
    --port 8000 \
    -c 2048 \
    -a Olmo-3-1125-32B-Think,Olmo-3-32B-Think,olmo-3-32b \
    -np 1 \
    -fa on \
    --reasoning-format deepseek \
    --reasoning-budget 1024 \
    --metrics
Restart=on-failure
RestartSec=15
TimeoutStartSec=300

[Install]
WantedBy=multi-user.target
