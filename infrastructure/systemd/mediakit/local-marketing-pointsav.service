[Unit]
Description=PointSav Marketing Landing (app-mediakit-marketing — pointsav tenant)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=foundry
Group=foundry

WorkingDirectory=/opt/mediakit/data/marketing-pointsav

Environment="SERVICE_MARKETING_CONTENT_DIR=/opt/mediakit/data/marketing-pointsav/content"
Environment="SERVICE_MARKETING_BIND=0.0.0.0:9101"
Environment="SERVICE_MARKETING_MODULE_ID=pointsav"
Environment="SERVICE_MARKETING_SITE_TITLE=PointSav"
Environment="SERVICE_MARKETING_GRAPH_URL=http://127.0.0.1:9081"

ExecStart=/opt/mediakit/bin/app-mediakit-marketing serve

Restart=on-failure
RestartSec=5s

NoNewPrivileges=true

StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
