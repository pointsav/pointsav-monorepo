{
  "package": {
    "productName": "Workplace Presentation",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "dialog": {
        "open": true,
        "save": true
      },
      "fs": {
        "readFile": true,
        "writeFile": true,
        "exists": true,
        "createDir": true,
        "scope": ["$APPDATA/workplace-presentation/**", "$HOME/**"]
      },
      "path": {
        "all": true
      },
      "window": {
        "print": true
      },
      "shell": {
        "open": false,
        "execute": false
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.pointsav.workplace.presentation",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "copyright": "© 2026 PointSav Digital Systems",
      "category": "Productivity",
      "shortDescription": "Sovereign offline presentation editor",
      "longDescription": "A local-first presentation editor producing self-contained HTML files. No cloud. No account. EUPL-1.2 licensed.",
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0 | libwebkit2gtk-4.0-37"]
      },
      "macOS": {
        "minimumSystemVersion": "10.13"
      },
      "resources": []
    },
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'none'; img-src 'self' data:; font-src 'self' data:",
      "dangerousDisableAssetCspModification": false,
      "freezePrototype": true
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "Workplace Presentation",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 640,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "updater": {
      "active": false
    }
  },
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "npm run embed-fonts",
    "devPath": "../src",
    "distDir": "../src",
    "withGlobalTauri": true
  }
}
