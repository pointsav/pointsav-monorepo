{
  "package": {
    "productName": "Workplace Presentation",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "dialog": {
        "open": true,
        "save": true
      },
      "fs": {
        "readFile": true,
        "writeFile": true,
        "exists": true,
        "createDir": true,
        "scope": ["$APPDATA/workplace-presentation/**", "$HOME/**"]
      },
      "path": {
        "all": true
      },
      "shell": {
        "open": false,
        "execute": false
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "systems.pointsav.workplace-presentation",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "copyright": "© 2026 PointSav Digital Systems",
      "category": "Productivity",
      "shortDescription": "Sovereign offline presentation tool",
      "longDescription": "A local-first presentation tool producing self-contained output. No cloud. No account. EUPL-1.2 licensed.",
      "macOS": {
        "minimumSystemVersion": "10.13"
      }
    },
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'none'; img-src 'self' data:; font-src 'self' data:"
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "Workplace Presentation",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "updater": {
      "active": false
    }
  },
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "../src",
    "distDir": "../src",
    "withGlobalTauri": true
  },
  "_notes": {
    "tauri-version": "v1.x — required for macOS 10.13 High Sierra. Upgrade to v2 when dev machine targets macOS 10.15+.",
    "phase": "Foundation skeleton only. Frontend (src/) and IPC commands pending Wave 1 implementation."
  }
}
